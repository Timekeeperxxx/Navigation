# 复制为 env.local 后按实际机器修改；兼容脚本会自动加载 env.local。
# 示例：
#   cp /home/jetson/Project/BOTDOG/Navigation/adapters/legacy_scripts/env.example /home/jetson/Project/BOTDOG/Navigation/adapters/legacy_scripts/env.local

export ROBOT_NAV_WS="/home/jetson/Project/BOTDOG/Navigation"
export ROBOT_NAV_MAP_ROOT="/home/jetson/Project/BOTDOG/MAPS"
export ROBOT_NAV_LOG_ROOT="/home/jetson/Project/BOTDOG/BotDog/logs"
export ROBOT_NAV_RUNTIME_ROOT="/home/jetson/Project/BOTDOG/BotDog/data/nav_runtime"

export ROS2_SETUP_FILE="/opt/ros/humble/setup.bash"
export ROS_DOMAIN_ID="${ROS_DOMAIN_ID:-0}"
export RMW_IMPLEMENTATION="${RMW_IMPLEMENTATION:-rmw_fastrtps_cpp}"
export NAV_FASTDDS_PROFILE="${ROBOT_NAV_WS}/adapters/legacy_scripts/fastdds_navigation.xml"

export LIVOX_LIDAR_IP="192.168.123.179"
export LIVOX_HOST_IP=""
export LIVOX_DEFAULT_HOST_IP="192.168.123.222"
export LIVOX_CONFIG_PATH="${ROBOT_NAV_RUNTIME_ROOT}/livox_mid360_config.json"

# Navigation 内置 nav_lio 当前对部分地图目录计算仍保留 ROOT 相对路径兼容。
export SUPERLIO_ROOT_DIR="${ROBOT_NAV_WS}/src/nav_lio"

# 多个额外 setup.bash 用英文冒号分隔。默认不加载外部工作区。
export NAV_EXTRA_SETUP_FILES=""

# 导航与底盘选择。当前开发板默认使用 Unitree B2。
export NAV_ENABLE_SCAN_PLANNER="true"
export NAV_ENABLE_SCAN_CONTROLLER="true"
export NAV_ENABLE_PATH_FOLLOWER="false"
export NAV_ENABLE_DYNAMIC_AVOIDANCE="true"
export NAV_ENABLE_ROBOT_CONTROL="false"
export NAV_ROBOT_MODEL="b2"
export NAV_ROBOT_CMD_VEL_TOPIC="/unitree/b2/cmd_vel"

# 仅 Go2 WebRTC 模式使用；连接后不会自动站立。
export NAV_GO2_CONNECTION_METHOD="LocalAP"
export NAV_GO2_IP=""
export NAV_GO2_SERIAL_NUMBER=""
export NAV_GO2_AES_128_KEY=""

# Python PCD 发布器会先在内存中解码；超限输入必须在大内存主机离线降采样。
export NAV_MAX_RAW_PCD_BYTES="67108864"
export NAV_MAX_RAW_PCD_POINTS="4000000"
