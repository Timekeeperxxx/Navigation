<launch>
  <!-- real or sim -->
  <arg name="is_real_world" default="false"/>

  <!-- navigation mode -->
  <!-- 1: use 2D Nav Goal to select final goal  -->
  <!-- 2: use keypoints to navigate in multi-floor scene -->
  <!-- 3: use reference path to follow and avoid obstacles -->
  <arg name="navi_mode" default="1"/>
  <arg name="sensor_type" default="lidar"/>

  <!-- body topic -->
  <arg name="body_pose_topic" value="$(eval '/LIO/odom_vehicle' if arg('is_real_world') else '/quad_0/body_pose')" />
  <param name="body_pose_topic" value="$(arg body_pose_topic)" type="str"/>

  <!-- main algorithm params -->
  <include file="$(find scan_planner)/launch/advanced_param.xml">

    <!-- sensor choose -->
    <arg name="sensor_type" value="$(arg sensor_type)"/>
    <arg name="body_pose_topic" value="$(arg body_pose_topic)" />
    <arg name="sensor_pose_topic" value="$(eval '/LIO/odom_imu' if arg('is_real_world') else ('/quad_0/camera_pose' if arg('sensor_type') == 'depth' else '/quad_0/lidar_pose'))" />

    <!-- lidar topic -->
    <arg name="cloud_topic" value="$(eval '/LIO/clouds_lidar' if arg('is_real_world') else '/pcl_render_node/cloud')"/>
    <arg name="cloud_is_world" value="$(eval 'false' if arg('is_real_world') else 'true')"/>

    <!-- depth topic -->
    <arg name="depth_topic" value="$(eval '/camera/aligned_depth_to_color/image_raw' if arg('is_real_world') else '/pcl_render_node/depth')"/>
    <arg name="cx" value="$(eval 317.19183349609375 if arg('is_real_world') else 321.04638671875)"/>
    <arg name="cy" value="$(eval 256.4806823730469 if arg('is_real_world') else 243.44969177246094)"/>
    <arg name="fx" value="$(eval 609.5884399414062 if arg('is_real_world') else 387.229248046875)"/>
    <arg name="fy" value="$(eval 609.22021484375 if arg('is_real_world') else 387.229248046875)"/>

    <arg name="is_real_world" value="$(arg is_real_world)"/>
    <arg name="navi_mode" value="$(arg navi_mode)" />
  </include>

  <!-- controller mode -->
  <!-- open_loop: publish trajectory-following odometry for multi-floor simulation -->
  <!-- closed_loop: track the trajectory for 2D simulation or real-world control -->
  <arg name="controller_mode" default="closed_loop"/>

  <node if="$(eval arg('controller_mode') == 'open_loop')" pkg="scan_planner" name="open_loop_controller" type="open_loop_controller" output="screen"/>
  <group if="$(eval arg('controller_mode') == 'closed_loop')">
    <node pkg="scan_planner" name="closed_loop_controller" type="closed_loop_controller" output="screen"/>
    <node unless="$(arg is_real_world)" pkg="scan_planner" name="go2_kinematic_sim" type="go2_kinematic_sim" output="screen"/>
  </group>

  <!-- go2 model -->
  <param name="robot_description" textfile="$(find go2_description)/urdf/go2_description.urdf" />
  <node pkg="robot_state_publisher" type="robot_state_publisher" name="go2_robot_state_publisher" output="screen"/>
  <node pkg="scan_planner" name="go2_gait_publisher" type="go2_gait_publisher" output="screen"/>

  <!-- use simulator -->
  <include file="$(find scan_planner)/launch/simulator.xml">
    <arg name="is_real_world" value="$(arg is_real_world)" />
    <arg name="sensor_type" value="$(arg sensor_type)" />
  </include>

</launch>
