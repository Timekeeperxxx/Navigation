Panels:
  - Class: rviz_common/Displays
    Help Height: 0
    Name: Displays
    Property Tree Widget:
      Expanded:
        - /Planning1
        - /Mapping1
        - /Mapping1/sim_map1/Autocompute Value Bounds1
        - /Simulation1
      Splitter Ratio: 0.5
    Tree Height: 692
  - Class: rviz_common/Selection
    Name: Selection
  - Class: rviz_common/Tool Properties
    Expanded:
      - /2D Nav Goal1
      - /Publish Point1
    Name: Tool Properties
    Splitter Ratio: 0.5886790156364441
  - Class: rviz_common/Views
    Expanded:
      - /Current View1
      - /ThirdPersonFollower1
    Name: Views
    Splitter Ratio: 0.5
  - Class: rviz_common/Time
    Name: Time
    SyncMode: 0
    SyncSource: inflate_map
Preferences:
  PromptSaveOnExit: true
Toolbars:
  toolButtonStyle: 2
